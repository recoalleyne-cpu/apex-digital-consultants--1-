# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google integrations (client-side)
# For Vite, use VITE_ prefixed names (preferred).
# Vercel aliases also supported: NEXT_PUBLIC_GOOGLE_* and GOOGLE_*.
# Any env change requires a fresh deployment to apply build-time values.
VITE_GOOGLE_ANALYTICS_ID=""
VITE_GOOGLE_TAG_MANAGER_ID=""
VITE_GOOGLE_ANALYTICS_USE_GTM_TRANSPORT="true"
VITE_GOOGLE_SEARCH_CONSOLE_VERIFICATION=""
VITE_GOOGLE_ADS_ID=""
VITE_GOOGLE_ADS_CONVERSION_LABEL=""
VITE_GOOGLE_RECAPTCHA_SITE_KEY=""
VITE_GOOGLE_MAPS_API_KEY=""
VITE_GOOGLE_FONTS_ENABLED="true"
VITE_GOOGLE_FONTS_STYLESHEET_URL=""
VITE_GOOGLE_DEBUG="false"

# Optional Vercel-style aliases (use only if needed)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=""

# Firebase (client-side, Vite build-time vars)
# Add these in Vercel Project Settings -> Environment Variables for
# Production/Preview/Development as needed, then redeploy.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Firebase Admin SDK (server-side, for API token verification only)
# Keep these private (no VITE_ prefix)
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
# Keep escaped newlines in .env files (\\n). Server code will convert them.
FIREBASE_ADMIN_PRIVATE_KEY=""

# Optional admin email allowlist for protected API access
# Example: "admin1@company.com,admin2@company.com"
ADMIN_ALLOWED_EMAILS=""

# Neon / Postgres (server-side only)
# Prefer DATABASE_URL. POSTGRES_URL remains supported as fallback.
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""
POSTGRES_URL=""

# Mailchimp (server-side only)
# Use non-VITE vars so API keys stay private.
MAILCHIMP_API_KEY=""
# Mailchimp list identifier (audience ID)
MAILCHIMP_AUDIENCE_ID=""
# Optional when not inferable from API key suffix (for example: us1)
MAILCHIMP_SERVER_PREFIX=""
